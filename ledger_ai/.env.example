GROQ_API_KEY=

# Optional Groq models (free tier: use smaller judge + fewer eval cases to avoid TPD limits)
# LEDGER_GROQ_JUDGE_MODEL=llama-3.1-8b-instant
# LEDGER_GROQ_ANSWER_MODEL=llama-3.3-70b-versatile
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_WAREHOUSE=

# Optional: blend synthetic amounts with a Kaggle-style payments CSV
# PAYMENTS_BASE_CSV=/path/to/payments.csv

# Optional: cap eval cases for a shorter first *non-mock* Groq run (default = all 60)
# LEDGER_EVAL_MAX_CASES=12
